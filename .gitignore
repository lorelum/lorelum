# ────────────────────────────────────────────────────────────
# OS / editor (always apply)
# ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ────────────────────────────────────────────────────────────
# Secrets & env (always apply)
# ────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ────────────────────────────────────────────────────────────
# Logs (always apply)
# ────────────────────────────────────────────────────────────
logs/
*.log

# ────────────────────────────────────────────────────────────
# Build outputs (generic)
# ────────────────────────────────────────────────────────────
dist/
build/
out/
.cache/

# ────────────────────────────────────────────────────────────
# Bun / TypeScript (toolchain locked)
# ────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# TypeScript incremental build cache
*.tsbuildinfo

# Test coverage
coverage/

# Note: bun.lock IS committed (text lockfile, Bun >= 1.2). Do not ignore it.

# Turborepo cache (uncomment if we adopt turborepo later)
# .turbo/
