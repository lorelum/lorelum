# ────────────────────────────────────────────────────────────
# OS / editor (always apply)
# ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ────────────────────────────────────────────────────────────
# Secrets & env (always apply)
# ────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ────────────────────────────────────────────────────────────
# Logs (always apply)
# ────────────────────────────────────────────────────────────
logs/
*.log

# ────────────────────────────────────────────────────────────
# Build outputs (generic)
# ────────────────────────────────────────────────────────────
dist/
build/
out/
.cache/

